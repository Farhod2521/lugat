# Server uchun muhit o'zgaruvchilari namunasi.
# Nusxa oling:  cp .env.prod.example .env.prod
# va qiymatlarni to'ldiring (parolni o'zgartiring!).

# --- PostgreSQL ---
POSTGRES_USER=lingvo
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=lingvodb

# --- CORS: qaysi frontend manzillariga ruxsat ---
# Vercel domeningiz (deploy qilgandan keyin aniq URL ni qo'ying).
# Bir nechta bo'lsa vergul bilan: https://app.vercel.app,https://lugat.testyarat.uz
CORS_ORIGINS=https://YOUR-APP.vercel.app
