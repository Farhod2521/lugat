# PostgreSQL ulanish manzili (Docker uchun docker-compose avtomatik beradi)
DATABASE_URL=postgresql://lingvo:lingvo123@db:5432/lingvodb

# Lokal ishlab chiqish uchun SQLite ishlatmoqchi bo'lsangiz:
# DATABASE_URL=sqlite:///lingvo.db

# CORS — qaysi frontend manzillariga ruxsat (vergul bilan ajratiladi).
# Lokalda bo'sh qoldirsangiz hammaga ruxsat beriladi (*).
# Production: CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=*
